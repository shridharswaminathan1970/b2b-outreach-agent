# .env.example
# Every environment variable used across the entire system.
# Copy this file to .env and fill in real values before running.
# See ENV_SPEC.md for full type/required/description documentation on each variable.
#
# Stack notes:
#  - Database is Supabase Postgres (DATABASE_URL pooled / DIRECT_URL session).
#  - The job queue runs on that same Postgres via pg-boss — there is NO Redis.
#  - Provider integrations (email/enrichment/CRM) and the Claude AI layer fall back
#    to deterministic mocks when their keys are absent, so the app runs out of the
#    box. Set USE_MOCK_*=false + real keys (and a real ANTHROPIC_API_KEY) to go live.
#  - The platform is multi-tenant: the first user/company is created by the seed.

## ══════════════════════════════════════════════════════
## DATABASE (Supabase Postgres)
## ══════════════════════════════════════════════════════
# Pooled connection used by the app at runtime. On Supabase use the TRANSACTION
# pooler (port 6543) with the aws-1- host prefix and username postgres.<ref>:
#   postgresql://postgres.<ref>:<pwd>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Direct/SESSION connection (port 5432). Used by Prisma Migrate AND by the worker's
# pg-boss queue (pg-boss requires a session connection — the transaction pooler is
# incompatible). URL-encode special chars in the password (@ -> %40, ! -> %21).
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

## ══════════════════════════════════════════════════════
## JOB QUEUE — pg-boss (NO REDIS)
## ══════════════════════════════════════════════════════
# The worker queue runs on the same Supabase Postgres via pg-boss (it creates a
# `pgboss` schema). There is NO Redis in this stack. pg-boss uses DIRECT_URL above.

## ══════════════════════════════════════════════════════
## API SERVICE
## ══════════════════════════════════════════════════════
NODE_ENV=development
API_PORT=3001
API_BASE_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

## ══════════════════════════════════════════════════════
## AUTHENTICATION & SECURITY
## ══════════════════════════════════════════════════════
JWT_SECRET=change_this_to_a_random_64_char_secret_before_production
JWT_REFRESH_SECRET=change_this_to_a_different_random_64_char_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

## ══════════════════════════════════════════════════════
## ANTHROPIC / CLAUDE AI
## ══════════════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL_DRAFT=claude-sonnet-4-6
ANTHROPIC_MODEL_CLASSIFY=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_RESEARCH=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS_DRAFT=1500
ANTHROPIC_MAX_TOKENS_CLASSIFY=300
ANTHROPIC_RETRY_ATTEMPTS=3
ANTHROPIC_RETRY_BASE_DELAY_MS=1000
CLASSIFY_CONFIDENCE_THRESHOLD=0.70

## ══════════════════════════════════════════════════════
## EMAIL DELIVERY — RESEND
## ══════════════════════════════════════════════════════
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM_ADDRESS=outreach@yourdomain.com
EMAIL_FROM_NAME=Muhammad Shaamel
EMAIL_REPLY_TO=shaamel@orangekloud.com
# Safe-by-default sender guard. Comma-separated domains verified with Resend that
# the from-address may use; a live send from any other (or a placeholder) domain
# is refused. resend.dev test addresses are always allowed. Leave blank in dev.
EMAIL_VERIFIED_DOMAINS=
EMAIL_DAILY_SEND_LIMIT=500
EMAIL_RATE_LIMIT_PER_HOUR=100
# Mock adapters are used by default so the system runs without provider keys.
# Set to false (and provide a real key above) to send live.
USE_MOCK_EMAIL=true

# SMTP (nodemailer) — alternative to Resend that sends through an existing
# authenticated mailbox (e.g. Google Workspace / Microsoft 365 with an app
# password), so it needs NO Resend domain verification. When SMTP_USER is set and
# USE_MOCK_EMAIL=false, SMTP takes precedence over Resend. Leave SMTP_USER blank
# to use Resend instead.
#   Google Workspace: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  (use an App Password)
#   Microsoft 365:    SMTP_HOST=smtp.office365.com SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Email tracking (open pixel + one-click unsubscribe). TRACKING_SECRET signs the
# tokens (falls back to JWT_SECRET if unset). PUBLIC_TRACKING_URL is the publicly
# reachable API origin email clients hit for the pixel/unsubscribe link — set it
# to your deployed API URL in production (falls back to API_BASE_URL).
TRACKING_SECRET=
PUBLIC_TRACKING_URL=
# Svix signing secret for the Resend inbound webhook (Resend dashboard → Webhooks).
# Only needed when sending via Resend; format whsec_...
RESEND_WEBHOOK_SECRET=

## ══════════════════════════════════════════════════════
## ENRICHMENT — APOLLO.IO
## ══════════════════════════════════════════════════════
APOLLO_API_KEY=your_apollo_api_key_here
APOLLO_API_BASE_URL=https://api.apollo.io/api/v1
ENRICHMENT_RATE_LIMIT_PER_MINUTE=20
USE_MOCK_ENRICHMENT=true

## ══════════════════════════════════════════════════════
## CRM — HUBSPOT
## ══════════════════════════════════════════════════════
HUBSPOT_ACCESS_TOKEN=pat-na1-your-hubspot-access-token
HUBSPOT_PORTAL_ID=your_portal_id
CRM_SYNC_ENABLED=true
USE_MOCK_CRM=true

## ══════════════════════════════════════════════════════
## FRONTEND (Web App)
## ══════════════════════════════════════════════════════
VITE_API_BASE_URL=http://localhost:3001
VITE_APP_NAME=Outreach Agent
VITE_APP_ENV=development

## ══════════════════════════════════════════════════════
## LOGGING
## ══════════════════════════════════════════════════════
LOG_LEVEL=info
LOG_FORMAT=pretty

## ══════════════════════════════════════════════════════
## WORKER (pg-boss)
## ══════════════════════════════════════════════════════
WORKER_PORT=3002
WORKER_CONCURRENCY_ENRICHMENT=5
WORKER_CONCURRENCY_GENERATION=3
WORKER_CONCURRENCY_SENDING=10
WORKER_CONCURRENCY_REPLY_CHECK=5
# Cron cadences (node-cron syntax) for the polling jobs.
REPLY_CHECK_CRON=*/5 * * * *
FOLLOWUP_CRON=*/10 * * * *
# Auto-create an Opportunity when the reply-check worker classifies a reply as
# "interested" (the worker's analog of an inbox conversion).
WORKER_AUTO_CREATE_OPPORTUNITY=true

## ══════════════════════════════════════════════════════
## SUPPRESSION & COMPLIANCE
## ══════════════════════════════════════════════════════
HARD_BOUNCE_AUTO_SUPPRESS=true
UNSUBSCRIBE_REDIRECT_URL=https://yourcompany.com/unsubscribed
UNSUBSCRIBE_SECRET=change_this_to_random_secret_for_unsubscribe_links
MAX_DAILY_SENDS_PER_CONTACT=1
GLOBAL_SUPPRESSION_CHECK_ENABLED=true

## ══════════════════════════════════════════════════════
## FEATURE FLAGS
## ══════════════════════════════════════════════════════
FEATURE_DRAFT_AUTO_APPROVE=false
FEATURE_MULTI_CHANNEL=false
FEATURE_AB_TESTING=false
FEATURE_MEETING_BOOKING=false

## ══════════════════════════════════════════════════════
## SEED DATA (used by packages/db/prisma/seed.ts)
## ══════════════════════════════════════════════════════
SEED_ADMIN_EMAIL=admin@yourcompany.com
SEED_ADMIN_PASSWORD=Admin@SecurePassword123
SEED_ADMIN_NAME=Muhammad Shaamel

## ══════════════════════════════════════════════════════
## PRODUCTION-ONLY VARIABLES (not needed in local dev)
## ══════════════════════════════════════════════════════
